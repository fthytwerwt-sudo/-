{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepseek_supply_request.schema.json",
  "title": "DeepSeek Supply Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "request_id",
    "project_route",
    "task_type",
    "trigger_reason",
    "action",
    "mandatory_for_every_task",
    "participation_level",
    "pre_supply_required",
    "post_review_required",
    "codex_vertical_completion_required",
    "token_usage_expectation",
    "fallback_allowed",
    "fallback_not_completion",
    "user_explicit_deepseek_required",
    "deepseek_must_not_be_skipped_by_codex_discretion",
    "current_goal",
    "current_step",
    "known_context",
    "missing_context",
    "candidate_files",
    "forbidden_paths",
    "expected_output",
    "not_allowed",
    "blocked_if",
    "return_to_codex"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "project_route": {
      "const": "video_factory"
    },
    "task_id": {
      "type": "string"
    },
    "task_type": {
      "type": "string",
      "minLength": 1
    },
    "project_stage": {
      "enum": [
        "formal_operation_active",
        "legacy_gray_test",
        "draft",
        "blocked"
      ]
    },
    "operation_stage": {
      "type": "string",
      "description": "Current formal operation stage, e.g. operation_data_intake, operation_review, operation_next_variable_decision, operation_stage_migration."
    },
    "current_operation_target_path": {
      "type": "string"
    },
    "operation_records_index_path": {
      "type": "string"
    },
    "legacy_previous_stage": {
      "type": "string"
    },
    "trigger_reason": {
      "enum": [
        "mandatory_pre_supply",
        "mandatory_post_risk_review",
        "missing_context",
        "rule_conflict",
        "stale_context_risk",
        "large_context",
        "before_write_gate",
        "after_read_gap",
        "user_explicit_deepseek"
      ]
    },
    "action": {
      "enum": [
        "file_map",
        "risk_report",
        "context_summary",
        "missing_files",
        "visual_asset_requirement_pack",
        "api_asset_generation_pack",
        "image_prompt_pack",
        "asset_validation_pack",
        "assembly_decision_pack",
        "editing_decision_pack",
        "auto"
      ]
    },
    "current_goal": {
      "type": "string",
      "minLength": 1
    },
    "current_north_star_goal": {
      "type": "string"
    },
    "current_stage_goal": {
      "type": "string"
    },
    "main_bottleneck": {
      "type": "string"
    },
    "primary_variable": {
      "type": "string"
    },
    "supporting_variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_metric": {
      "type": "string"
    },
    "failure_metric": {
      "type": "string"
    },
    "post_publish_validation_metric": {
      "type": "string"
    },
    "next_video_execution_prompt": {
      "type": "string"
    },
    "current_data_goal_anchor_path": {
      "type": "string"
    },
    "current_data_goal_anchor_status": {
      "enum": [
        "draft",
        "ready",
        "blocked",
        "waiting_data",
        "partial_data_recorded",
        "draft_with_interim_data"
      ]
    },
    "data_goal_anchor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "current_north_star_goal": {
          "type": "string"
        },
        "current_stage_goal": {
          "type": "string"
        },
        "threshold_config_v1": {
          "type": "object",
          "additionalProperties": true
        },
        "video_goal_card": {
          "type": "object",
          "additionalProperties": true
        },
        "post_publish_review_card": {
          "type": "object",
          "additionalProperties": true
        },
        "data_flywheel_memory": {
          "type": "object",
          "additionalProperties": true
        },
        "main_bottleneck": {
          "type": "string"
        },
        "primary_variable": {
          "type": "string"
        },
        "supporting_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "content_structure_feedback_card": {
          "type": "object",
          "additionalProperties": true
        },
        "next_video_structure_plan": {
          "type": "object",
          "additionalProperties": true
        },
        "next_video_execution_prompt": {
          "type": "string"
        },
        "success_metric": {
          "type": "string"
        },
        "failure_metric": {
          "type": "string"
        },
        "post_publish_validation_metric": {
          "type": "string"
        }
      }
    },
    "current_step": {
      "type": "string",
      "minLength": 1
    },
    "known_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_needed": {
      "type": "string"
    },
    "candidate_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_read_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_context_files": {
      "type": "integer",
      "minimum": 1
    },
    "max_context_chars": {
      "type": "integer",
      "minimum": 1
    },
    "expected_output": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_format": {
      "type": "string"
    },
    "codex_next_input": {
      "type": "string"
    },
    "return_to_codex": {
      "type": "object"
    },
    "not_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "stop_condition": {
      "type": "string"
    },
    "blocked_if": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallback_allowed": {
      "type": "boolean"
    },
    "mandatory_for_every_task": {
      "type": "boolean",
      "const": true
    },
    "participation_level": {
      "enum": [
        "mandatory_by_default",
        "user_explicit_required",
        "fallback_local_only",
        "blocked"
      ]
    },
    "pre_supply_required": {
      "type": "boolean",
      "const": true
    },
    "post_review_required": {
      "type": "boolean",
      "const": true
    },
    "codex_vertical_completion_required": {
      "type": "boolean",
      "const": true
    },
    "token_usage_expectation": {
      "enum": [
        "token_should_decrease_if_real_call",
        "user_check_required_when_unobservable"
      ]
    },
    "fallback_not_completion": {
      "type": "boolean",
      "const": true
    },
    "user_explicit_deepseek_required": {
      "type": "boolean"
    },
    "deepseek_must_not_be_skipped_by_codex_discretion": {
      "type": "boolean",
      "const": true
    },
    "fallback_policy": {
      "type": "string"
    },
    "source_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "narration_lines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contact_sheet_description": {
      "type": "string"
    },
    "ocr_text": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frame_descriptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "reference_quality_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "editing_question": {
      "type": "string"
    },
    "script_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "content_route_card": {
      "type": "object",
      "additionalProperties": true
    },
    "content_structure_feedback_card": {
      "type": "object",
      "additionalProperties": true
    },
    "next_video_structure_plan": {
      "type": "object",
      "additionalProperties": true
    },
    "threshold_config_v1": {
      "type": "object",
      "additionalProperties": true
    },
    "video_goal_card": {
      "type": "object",
      "additionalProperties": true
    },
    "post_publish_review_card": {
      "type": "object",
      "additionalProperties": true
    },
    "data_flywheel_memory": {
      "type": "object",
      "additionalProperties": true
    },
    "data_goal_alignment_check_required": {
      "type": "boolean"
    },
    "data_goal_alignment_check": {
      "type": "object",
      "additionalProperties": true
    },
    "data_goal_supply_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visual_asset_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "api_generation_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "image_prompt_specs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "asset_validation_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "assembly_slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "fallback_plan": {
      "type": "string"
    },
    "vendor_constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "api_call_policy": {
      "type": "string"
    },
    "secret_policy": {
      "type": "string"
    },
    "allow_process_env_api_key": {
      "type": "boolean"
    },
    "disable_env_file": {
      "type": "boolean"
    },
    "safe_deepseek_process_env_test": {
      "type": "boolean"
    },
    "requires_real_deepseek_participation": {
      "type": "boolean"
    },
    "safe_loader_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "enum": [
            "project_runtime_provider",
            "process_env_only",
            "authorized_subprocess_env_loader_required",
            "local_fallback_only"
          ]
        },
        "runtime_provider_required": {
          "type": "boolean"
        },
        "runtime_provider_load_order": {
          "type": "array",
          "items": {
            "enum": [
              "process_env",
              "project_env_local",
              "project_env",
              "local_runtime_authorization"
            ]
          }
        },
        "controller_or_explorer_may_read_env_file": {
          "type": "boolean",
          "const": false
        },
        "allow_env_file_loader": {
          "type": "boolean"
        },
        "require_user_authorization_for_env_loader": {
          "type": "boolean"
        },
        "blocked_if_process_env_missing": {
          "type": "boolean"
        },
        "api_key_printed": {
          "type": "boolean",
          "const": false
        },
        "api_key_written": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "runtime_provider": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider_name": {
          "const": "deepseek_runtime_provider"
        },
        "auto_load_enabled": {
          "type": "boolean"
        },
        "inject_to_child_process_only": {
          "type": "boolean",
          "const": true
        },
        "never_print_key": {
          "type": "boolean",
          "const": true
        },
        "never_write_key": {
          "type": "boolean",
          "const": true
        },
        "blocked_if_provider_not_ready": {
          "type": "boolean"
        }
      }
    },
    "deepseek_readiness_check_required": {
      "type": "boolean"
    },
    "safe_call_mode": {
      "type": "string"
    },
    "readiness_expected_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
