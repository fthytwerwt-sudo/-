        "V001 01:36-02:09",
        "V003 00:51-01:30"
      ],
      "expected_visual": "商品卡近景 + 明细表字段列，逐个高亮字段名。",
      "card_text_if_any": "初筛字段：价格 / 佣金 / 销量 / 评分 / 风险 / 可拍性"
