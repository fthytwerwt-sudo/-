{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepseek_supply_request.schema.json",
  "title": "DeepSeek Supply Request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "request_id",
    "project_route",
    "task_type",
    "trigger_reason",
    "action",
    "mandatory_for_every_task",
    "participation_level",
    "pre_supply_required",
    "post_review_required",
    "codex_vertical_completion_required",
    "token_usage_expectation",
    "fallback_allowed",
    "fallback_not_completion",
    "user_explicit_deepseek_required",
    "deepseek_must_not_be_skipped_by_codex_discretion",
    "current_goal",
    "current_step",
    "known_context",
    "missing_context",
    "candidate_files",
    "forbidden_paths",
    "expected_output",
    "not_allowed",
    "blocked_if",
    "return_to_codex"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "project_route": {
      "const": "video_factory"
    },
    "task_id": {
      "type": "string"
    },
    "task_type": {
      "type": "string",
      "minLength": 1
    },
    "trigger_reason": {
      "enum": [
        "mandatory_pre_supply",
        "mandatory_post_risk_review",
        "missing_context",
        "rule_conflict",
        "stale_context_risk",
        "large_context",
        "before_write_gate",
        "after_read_gap",
        "user_explicit_deepseek"
      ]
    },
    "action": {
      "enum": [
        "file_map",
        "risk_report",
        "context_summary",
        "missing_files",
        "visual_asset_requirement_pack",
        "api_asset_generation_pack",
        "image_prompt_pack",
        "asset_validation_pack",
        "assembly_decision_pack",
        "editing_decision_pack",
        "auto"
      ]
    },
    "current_goal": {
      "type": "string",
      "minLength": 1
    },
    "current_step": {
      "type": "string",
      "minLength": 1
    },
    "known_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_needed": {
      "type": "string"
    },
    "candidate_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_read_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_context_files": {
      "type": "integer",
      "minimum": 1
    },
    "max_context_chars": {
      "type": "integer",
      "minimum": 1
    },
    "expected_output": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_format": {
      "type": "string"
    },
    "codex_next_input": {
      "type": "string"
    },
    "return_to_codex": {
      "type": "object"
    },
    "not_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "stop_condition": {
      "type": "string"
    },
    "blocked_if": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallback_allowed": {
      "type": "boolean"
    },
    "mandatory_for_every_task": {
      "type": "boolean",
      "const": true
    },
    "participation_level": {
      "enum": [
        "mandatory_by_default",
        "user_explicit_required",
        "fallback_local_only",
        "blocked"
      ]
    },
    "pre_supply_required": {
      "type": "boolean",
      "const": true
    },
    "post_review_required": {
      "type": "boolean",
      "const": true
    },
    "codex_vertical_completion_required": {
      "type": "boolean",
      "const": true
    },
    "token_usage_expectation": {
      "enum": [
        "token_should_decrease_if_real_call",
        "user_check_required_when_unobservable"
      ]
    },
    "fallback_not_completion": {
      "type": "boolean",
      "const": true
    },
    "user_explicit_deepseek_required": {
      "type": "boolean"
    },
    "deepseek_must_not_be_skipped_by_codex_discretion": {
      "type": "boolean",
      "const": true
    },
    "fallback_policy": {
      "type": "string"
    },
    "source_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "narration_lines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contact_sheet_description": {
      "type": "string"
    },
    "ocr_text": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frame_descriptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "reference_quality_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "editing_question": {
      "type": "string"
    },
    "script_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "content_route_card": {
      "type": "object",
      "additionalProperties": true
    },
    "visual_asset_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "api_generation_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "image_prompt_specs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "asset_validation_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "assembly_slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "fallback_plan": {
      "type": "string"
    },
    "vendor_constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "api_call_policy": {
      "type": "string"
    },
    "secret_policy": {
      "type": "string"
    },
    "allow_process_env_api_key": {
      "type": "boolean"
    },
    "disable_env_file": {
      "type": "boolean"
    },
    "safe_deepseek_process_env_test": {
      "type": "boolean"
    },
    "deepseek_readiness_check_required": {
      "type": "boolean"
    },
    "safe_call_mode": {
      "type": "string"
    },
    "readiness_expected_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
